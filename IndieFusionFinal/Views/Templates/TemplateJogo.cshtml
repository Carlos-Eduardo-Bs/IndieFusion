@model IndieFusionFinal.Models.Game

@{
    ViewData["Title"] = "Index";
    var userId = Context.Session.GetInt32("UserId");
    var userType = Context.Session.GetInt32("UserType");
    var username = Context.Session.GetString("Username"); //Obtém o nome de usuário da sessão usando Context
    var imagePath = Context.Session.GetString("ImagePath") ?? "/IF/Img/Icones/PerfilWhite.png";
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="">
    <link rel="stylesheet" href="./Css/Media.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/remixicon/4.2.0/remixicon.css" referrerpolicy="no-referrer" />
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/css/lightbox.min.css" />
    <title>IndieFusion</title>
</head>
<header>
    <nav>
        <!-- Top Bar -->
        <section id="top" class="topbar">
            <div class="topbar_container">
                <div class="topbar__content">
                    <div class="logo-container">
                        <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">
                            <div class="topbar__logo">
                                <h4 class="logo-text">
                                    INDIE
                                    <span> FUSION</span>
                                </h4>
                            </div>
                        </a>
                    </div>
                    <div class="topbar__menuhome">
                        <ul>
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                            @if (userId == null)
                            {
                                <li>
                                    <a href="#" class="nav-link" data-bs-toggle="modal" data-bs-target="#loginModal">Login</a>
                                </li>
                                <li>
                                    <a href="#" class="nav-link " data-bs-toggle="modal" data-bs-target="#cadastroModal">Cadastrar</a>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="topbar__menuhomePerfil">
                        @if (userId != null)
                        {
                            <li class="perfil-container">
                                <button id="perfilBtn">
                                    <img src="@Url.Content(imagePath)" alt="Perfil" class="img-thumbnail" />
                                </button>
                                <span id="perfilNome" class="perfil-nome">@username.ToUpper()</span>
                                <div id="menu" class="menu">
                                    @if (userType == 1)
                                    {
                                        <a asp-area="" asp-controller="Users" asp-action="Index">Área Restrita</a>
                                        <a asp-area="" asp-controller="Home" asp-action="Logout">Logout</a>
                                    }
                                    else if (userType == 2)
                                    {
                                        <a asp-area="" asp-controller="GameMakers" asp-action="GameUser">Meus Jogos</a>
                                        <a asp-area="" asp-controller="Templates" asp-action="TemplatePerfil">Perfil</a>
                                        <a asp-area="" asp-controller="Home" asp-action="Logout">Logout</a>
                                    }
                                    else
                                    {
                                        <a asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                                        <a asp-area="" asp-controller="Templates" asp-action="TemplatePerfil">Perfil</a>
                                        <a asp-area="" asp-controller="Home" asp-action="Logout">Logout</a>
                                    }
                                </div>
                            </li>
                        }

                        <div class="mode-container">
                            <button id="btnMode" class="topbar__btn">
                                <img src="~/Img/Icones/moon.png" alt="Modo Escuro">
                            </button>
                            <span class="mode-nome">Temas</span>
                        </div>

                        <!-- Menu de seleção de temas -->
                        <div id="themeMenu" class="theme-menu">
                            <div class="theme-group">
                                <div class="theme-category" onclick="toggleThemeOptions('light')">Light Mode</div>
                                <div class="theme-options" id="light-options">
                                    <div class="theme-option" onclick="changeTheme('NebulosaSolarLightMode')">Nebulosa Solar</div>
                                    <div class="theme-option" onclick="changeTheme('AuroraNebulosaLightMode')">Aurora Nebulosa</div>
                                    <div class="theme-option" onclick="changeTheme('GalaxiaAzuladaLightMode')">Galáxia Azulada</div>
                                    <div class="theme-option" onclick="changeTheme('NebulosaLilasLightMode')">Nebulosa Lilás</div>
                                    <div class="theme-option" onclick="changeTheme('EstrelaDouradaLightMode')">Estrela Dourada</div>
                                </div>
                            </div>

                            <div class="theme-group">
                                <div class="theme-category" onclick="toggleThemeOptions('dark')">Dark Mode</div>
                                <div class="theme-options" id="dark-options">
                                    <div class="theme-option" onclick="changeTheme('NebulosaVermelhaMode')">Nebulosa Vermelha</div>
                                    <div class="theme-option" onclick="changeTheme('BuracoNegroMode')">Buraco Negro</div>
                                    <div class="theme-option" onclick="changeTheme('AuroraBorealMode')">Aurora Boreal</div>
                                    <div class="theme-option" onclick="changeTheme('EstrelaAzulMode')">Estrela Azul</div>
                                    <div class="theme-option" onclick="changeTheme('NebulosaLilasMode')">Nebulosa Lilás</div>
                                </div>
                            </div>

                            <div class="theme-group">
                                <div class="theme-category" onclick="toggleThemeOptions('neon')">Neon Mode</div>
                                <div class="theme-options" id="neon-options">
                                    <div class="theme-option" onclick="changeTheme('Neon1Mode')">Neon Trifecta</div>
                                    <div class="theme-option" onclick="changeTheme('NeonSpectrumMode')">Neon Spectrum</div>
                                    <div class="theme-option" onclick="changeTheme('NeonVaporwaveMode')">Neon Vaporwave</div>
                                    <div class="theme-option" onclick="changeTheme('NeonCyberMode')">Neon Cyber</div>
                                    <div class="theme-option" onclick="changeTheme('NeonAuroraMode')">Neon Aurora</div>
                                </div>
                            </div>

                            <div class="theme-group">
                                <div class="theme-category" onclick="toggleThemeOptions('colors')">Cores Padrões</div>
                                <div class="theme-options" id="colors-options">
                                    <div class="theme-option" onclick="changeTheme('GalaxiaPadraoMode')">Galáxia Padrão</div>
                                    <div class="theme-option" onclick="changeTheme('darkGalaxyAMOLEDMode')">Dark Galaxy</div>
                                    <div class="theme-option" onclick="changeTheme('GalaxiaPadraoLightMode')">Light Galaxy</div>
                                    <div class="theme-option" onclick="changeTheme('YingYangNeonGalaticoMode')">Ying Yang Galatico</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Modal Login -->
        <div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="loginModalLabel">Login</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form asp-action="Login" method="post">
                            <div class="mb-3">
                                <label for="nickname" class="form-label">Usuário</label>
                                <input type="text" class="form-control" id="nickname" name="nickname" required>
                            </div>
                            <div class="mb-3">
                                <label for="password" class="form-label">Senha</label>
                                <input type="password" class="form-control" id="password" name="password" required>
                            </div>
                            <!-- Área para exibir a mensagem de erro -->
                            <div id="errorMessage" class="alert alert-danger" style="display: none;">
                                <!-- Mensagem de erro será exibida aqui -->
                            </div>
                            <button type="submit" class="btn btn-primary">Login</button>
                        </form>
                        <p class="mt-3">
                            Não tem conta?
                            <a href="#" id="linkCadastro">Crie uma!</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Cadastro -->
        <div class="modal fade" id="cadastroModal" tabindex="-1" aria-labelledby="cadastroModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="cadastroModalLabel">Cadastrar Usuário</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form asp-action="Cadastro" method="post" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label for="name" class="form-label">Nome</label>
                                <input type="text" class="form-control" id="name" name="name" required>
                            </div>
                            <div class="mb-3">
                                <label for="nickname" class="form-label">NickName</label>
                                <input type="text" class="form-control" id="nickname" name="nickname" required>
                            </div>
                            <div class="mb-3">
                                <label for="email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="email" name="email" required>
                            </div>
                            <div class="mb-3">
                                <label for="password" class="form-label">Senha</label>
                                <input type="password" class="form-control" id="password" name="password" required minlength="6">
                            </div>
                            <div class="mb-3">
                                <label for="birthDate" class="form-label">Data de Nascimento</label>
                                <input type="date" class="form-control" id="birthDate" name="birthDate" required>
                            </div>
                            <div class="mb-3">
                                <label for="imageFile" class="form-label">Imagem</label>
                                <input type="file" class="form-control" id="imageFile" name="imageFile">
                            </div>
                            <button type="submit" class="btn btn-primary">Cadastrar</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <section id="NavLeft" class="sidebar">
            <div class="sidebar_container">
                <ul class="sidebar__menu">
                    <!-- Item do Menu (sem link) -->
                    <li>
                        <div class="menu-item">
                            <!-- Link para a ação TemplateFiltro no controller Templates -->
                            <a asp-controller="Templates" asp-action="TemplateFiltro" asp-area="">
                                <span>Menu</span>
                                <img src="~/Img/Icones/menuBar.webp" alt="Menu">
                            </a>
                        </div>
                    </li>
                    <!-- Aventura -->
                    <li>
                        <a href="@Url.Action("TemplateFiltro", "Templates", new { nomeJogo = "", Classification_Id = "", Genre_Id = 6 })">
                            <div class="menu-item">
                                <span>Aventura</span>
                                <img src="~/Img/Icones/Bag.png" alt="Aventura">
                            </div>
                        </a>
                    </li>
                    <!-- Plataforma -->
                    <li>
                        <a href="@Url.Action("TemplateFiltro", "Templates", new { nomeJogo = "", Classification_Id = "", Genre_Id = 2 })">
                            <div class="menu-item">
                                <span>Plataforma</span>
                                <img src="~/Img/Icones/Block.png" alt="Plataforma">
                            </div>
                        </a>
                    </li>
                    <!-- Corrida -->
                    <li>
                        <a href="@Url.Action("TemplateFiltro", "Templates", new { nomeJogo = "", Classification_Id = "", Genre_Id = 3 })">
                            <div class="menu-item">
                                <span>Corrida</span>
                                <img src="~/Img/Icones/Car.png" alt="Corrida">
                            </div>
                        </a>
                    </li>
                    <!-- RPG -->
                    <li>
                        <a href="@Url.Action("TemplateFiltro", "Templates", new { nomeJogo = "", Classification_Id = "", Genre_Id = 8 })">
                            <div class="menu-item">
                                <span>RPG</span>
                                <img src="~/Img/Icones/Dice.png" alt="RPG">
                            </div>
                        </a>
                    </li>
                    <!-- Tiro -->
                    <li>
                        <a href="@Url.Action("TemplateFiltro", "Templates", new { nomeJogo = "", Classification_Id = "", Genre_Id = 5 })">
                            <div class="menu-item">
                                <span>Tiro</span>
                                <img src="~/Img/Icones/Mira.png" alt="Tiro">
                            </div>
                        </a>
                    </li>
                    <!-- Luta -->
                    <li>
                        <a href="@Url.Action("TemplateFiltro", "Templates", new { nomeJogo = "", Classification_Id = "", Genre_Id = 1 })">
                            <div class="menu-item">
                                <span>Luta</span>
                                <img src="~/Img/Icones/Punch.png" alt="Luta">
                            </div>
                        </a>
                    </li>
                    <!-- Terror -->
                    <li>
                        <a href="@Url.Action("TemplateFiltro", "Templates", new { nomeJogo = "", Classification_Id = "", Genre_Id = 4 })">
                            <div class="menu-item">
                                <span>Terror</span>
                                <img src="~/Img/Icones/Skel.png" alt="Terror">
                            </div>
                        </a>
                    </li>
                    <!-- Info -->
                    <li>
                        <a href="/">
                            <div class="menu-item">
                                <span>Info</span>
                                <img src="~/Img/Icones/inf.png" alt="Info">
                            </div>
                        </a>
                    </li>
                    <!-- Logo -->
                    <div class="sidebar__logo">
                        <img src="~/Img/Icones/Logo.png" alt="Logo IndieFusion">
                    </div>
                </ul>
            </div>
        </section>
    </nav>
</header>

<main>
    <div class="Main-Perfil">
        <div class="banner">
            <img id="banner" src="@Url.Content(Model.BannerImage)" alt="Imagem Principal" style="width: 100%; height: 100%; object-fit: fill; border-radius: 8px;" />
        </div>

        <!-- Container do Perfil -->
        <div class="perfil-container">
            <div class="Inform-CardPerfil">
                <!-- Imagem do Perfil -->
                <div class="cardperfil-img">
                    <img src="@Url.Content(Model.User?.ImagePath ?? "/Img/Icones/usuario.png")" alt="Imagem de Perfil">
                </div>

                <!-- Informações do Usuário -->
                <div class="cardperfil-info">
                    <span class="nickname">@Model.User?.NickName</span>
                    <span class="apelido">@Model.User?.Name</span>
                </div>
            </div>
        </div>

        <!-- Avaliação do jogo -->
        <div class="JogosInfo">
           
            <div class="JogosInfo-Container">
                <!-- Primeiro quadrado: Slide de Imagens -->
                <div class="SlideImageJogo_Container">
                    <div class="image-slide">
                        <img id="mainImage" src="@Url.Content(Model.ImagePath)" alt="Imagem Principal" style="width: 100%;  height: 500px; object-fit: fill; border-radius: 8px;" />
                    </div>

                    <!-- Carrossel de Imagens -->
                    <div class="carousel-container">
                        <button class="carousel-button prev" onclick="moveCarousel(-1)">&#10094;</button>
                        <div class="carousel">

                            @if (!string.IsNullOrEmpty(Model.AdditionalImage1))
                            {
                                <img src="@Url.Content(Model.AdditionalImage1)" alt="Imagem 1" class="carousel-image"
                                     onclick="selectImage(this)" />
                            }
                            @if (!string.IsNullOrEmpty(Model.AdditionalImage2))
                            {
                                <img src="@Url.Content(Model.AdditionalImage2)" alt="Imagem 2" class="carousel-image"
                                     onclick="selectImage(this)" />
                            }
                            @if (!string.IsNullOrEmpty(Model.AdditionalImage3))
                            {
                                <img src="@Url.Content(Model.AdditionalImage3)" alt="Imagem 3" class="carousel-image"
                                     onclick="selectImage(this)" />
                            }
                            @if (!string.IsNullOrEmpty(Model.AdditionalImage4))
                            {
                                <img src="@Url.Content(Model.AdditionalImage4)" alt="Imagem 4" class="carousel-image"
                                     onclick="selectImage(this)" />
                            }
                        </div>
                        <button class="carousel-button next" onclick="moveCarousel(1)">&#10095;</button>
                    </div>
                </div>

                <!-- Segundo quadrado: Imagem do Jogo + Avaliação -->
                <div class="AvaliaçãoInfo-Container">
                    <!-- Imagem do jogo -->
                    <div class="jogo-imagem">
                        <img src="@Url.Content(Model.ImagePath)" alt="@Model.Title" class="game-image" style="width: 100%;" />
                    </div>
                        <h2 class="game-title">@Html.DisplayFor(model => model.Title)</h2>

                    <!-- Informações do jogo -->
                    <div class="info-container">
                        <div class="info-item">
                            <span class="info-label">Classificação:</span>
                            <span class="info-value">@Html.DisplayFor(model => model.Classification.Description)</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Gênero:</span>
                            <span class="info-value">@Html.DisplayFor(model => model.Genre.Description)</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Gênero 2:</span>
                            <span class="info-value">
                                @if (Model.Genre2 != null)
                                {
                                    @Html.DisplayFor(model => model.Genre2.Description)
                                }
                                else
                                {
                                    <span>N/A</span>
                                }
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Preço:</span>
                            <span class="info-value">@Html.DisplayFor(model => model.price)</span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Comentários -->
            <h3>Comentários:</h3>

            <div class="ParteComentario">
                <div class="ParteComentario-Container">
                    <!-- Primeiro quadrado: Slide de Imagens -->
                    <div class="PostComent-container">
                        <div class="Comentario-Container">
                            <div class="reviews">
                                @if (Model.Reviews != null && Model.Reviews.Count > 0)
                                {
                                    foreach (var review in Model.Reviews)
                                    {
                                        <div class="review">
                                            <p>
                                                <!-- Imagem de Like ou Dislike -->
                                                <img src="@(review.Like ? "/Img/Icones/LikeWhite.png" : "/Img/Icones/DislikeWhite.png")"
                                                     alt="@(review.Like ? "Like" : "Dislike")"
                                                     class="like-dislike-img" />
                                                <!-- Texto Recomendado/Não Recomendado -->
                                                <strong>@(review.Like ? "Recomendado" : "Não Recomendado")</strong>
                                                <!-- Nome do usuário -->
                                                - @(review.User?.Name ?? "Usuário Desconhecido")
                                            </p>
                                            <!-- Comentário -->
                                            @if (!string.IsNullOrEmpty(review.Comment))
                                            {
                                                <p>@review.Comment</p>
                                            }
                                            <hr />
                                        </div>
                                    }
                                }
                                else
                                {
                                    <p>Nenhum comentário ainda.</p>
                                }
                            </div>
                        </div>
                    </div>


                    <div class="Comentar-container">
                        <div class="reviews">
                            <h3>Deixe seu Comentário</h3>
                            <form method="post" asp-action="SubmitReview" asp-controller="Review">
                                <input type="hidden" name="gameId" value="@Model.Id" />

                                <div class="like-dislike-buttons">
                                    <label>
                                        <input type="radio" name="like" value="true" checked>
                                        <img src="/Img/Icones/Like.png" alt="Like" class="like-dislike-img">
                                    </label>
                                    <label>
                                        <input type="radio" name="like" value="false">
                                        <img src="/Img/Icones/Dislike.png" alt="Dislike" class="like-dislike-img">
                                    </label>
                                </div>


                                <textarea name="comment" placeholder="Escreva seu comentário..." required></textarea>
                                <button class="ComentButtonsub" type="submit">Enviar Comentário</button>
                            </form>
                        </div>
                    </div>
                </div>




                <!-- Formulário de Comentário -->
            </div>
        </div>
</main>
<script src="~/js/script.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Seleciona a primeira imagem do carrossel por padrão ao carregar a página
        var firstImage = document.querySelector('.carousel-image');
        if (firstImage) {
            selectImage(firstImage);
        }
    });

    // Função para alterar a imagem principal ao clicar no carrossel
    function selectImage(imgElement) {
        var mainImage = document.getElementById("mainImage");
        if (mainImage) {
            mainImage.src = imgElement.src;
            // Remover a classe 'selected' de todas as imagens
            var images = document.querySelectorAll('.carousel-image');
            images.forEach(function(image) {
                image.classList.remove('selected');
            });
            // Adicionar a classe 'selected' à imagem clicada
            imgElement.classList.add('selected');
        } else {
            console.error("Elemento mainImage não encontrado!");
        }
    }

    // Função para mover o carrossel
    function moveCarousel(direction) {
        var images = document.querySelectorAll('.carousel-image');
        var currentIndex = -1;

        // Encontra o índice da imagem selecionada
        images.forEach(function(image, index) {
            if (image.classList.contains('selected')) {
                currentIndex = index;
            }
        });

        // Calcula o novo índice
        var newIndex = currentIndex + direction;

        // Verifica se o novo índice está dentro dos limites do carrossel
        if (newIndex >= 0 && newIndex < images.length) {
            // Remove a seleção da imagem atual
            if (currentIndex !== -1) {
                images[currentIndex].classList.remove('selected');
            }
            // Adiciona a seleção à nova imagem
            images[newIndex].classList.add('selected');
            // Atualiza a imagem principal
            selectImage(images[newIndex]);
        }
    }
      document.getElementById("perfilBtn").addEventListener("click", function () {
            var menu = document.getElementById("menu");
            menu.classList.toggle("active");
        });
</script>



