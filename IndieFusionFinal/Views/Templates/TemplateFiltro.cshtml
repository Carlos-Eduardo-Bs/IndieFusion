@model IEnumerable<IndieFusionFinal.Models.Game>

@{
    ViewData["Title"] = "Filtro de Jogos";
    var imagePath = Context.Session.GetString("ImagePath") ?? "/IF/Img/Icones/PerfilWhite.png";
    var genreImage = Model.FirstOrDefault()?.Genre?.ImagePath;
}

